@model Product
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h3>➕ Thêm sản phẩm</h3>
<div asp-validation-summary="All" class="text-danger"></div>
<form asp-action="Create" method="post" enctype="multipart/form-data">
    @* <input type="hidden" asp-for="Id" /> *@

    <input asp-for="Name" class="form-control mb-2" placeholder="Tên sản phẩm" />

    <textarea asp-for="Description" class="form-control mb-2" placeholder="Mô tả"></textarea>

    <input asp-for="Price" class="form-control mb-2" placeholder="Giá" />

    <input asp-for="Stock" class="form-control mb-2" placeholder="Số lượng" />

    <input asp-for="Size" class="form-control mb-2" placeholder="Size (S,M,L...)" />

    <input asp-for="Color" class="form-control mb-2" placeholder="Màu" />

    <input type="file" name="ImageFile" class="form-control mb-2" placeholder="Tên file ảnh" />

    <select asp-for="CategoryId" class="form-control mb-3">
        <option value="0" disabled selected>-- Chọn danh mục --</option>
        @foreach (var c in ViewBag.Categories)
        {
            <option value="@c.Id">@c.Name</option>
        }
    </select>

    <span asp-validation-for="CategoryId" class="text-danger"></span>

    <button type="submit" class="btn btn-success">Lưu</button>

</form>