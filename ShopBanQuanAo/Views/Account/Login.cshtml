@model LoginVM

@{
    ViewData["Title"] = "Login";
    Layout = null; // nếu muốn dùng layout thì xóa dòng này
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Đăng nhập</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            height: 100vh;
            background: #f4f6f9;
            overflow: hidden;
        }

        .curve-bg {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 50%;
            background: linear-gradient(135deg, #4e73df, #6f42c1);
            border-top-left-radius: 100% 80%;
            border-top-right-radius: 100% 80%;
            z-index: 1;
        }

        .login-card {
            z-index: 2;
            border-radius: 20px;
            padding: 30px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .login-title {
            font-weight: bold;
            color: #4e73df;
        }

        .btn-login {
            background: #4e73df;
            border: none;
        }

        .btn-login:hover {
            background: #2e59d9;
        }
    </style>
</head>
<body>

    <div class="curve-bg"></div>

    <div class="d-flex justify-content-center align-items-center vh-100 position-relative">
        <div class="card login-card">

            <h3 class="text-center mb-4 login-title">Đăng nhập</h3>
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }
            <form asp-action="Login" method="post">

                <!-- Validation summary -->
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" placeholder="Nhập email" />
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu" />
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>

                <button type="submit" class="btn btn-login w-100 text-white">
                    Đăng nhập
                </button>

            </form>

            <div class="text-center mt-3">
                <small>Chưa có tài khoản? <a asp-action="Register">Đăng ký</a></small>
            </div>

        </div>
    </div>

    <!-- Validate -->
    <partial name="_ValidationScriptsPartial" />

</body>
</html>

