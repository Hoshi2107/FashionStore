@model User
@{
    ViewData["Title"] = "Register";
    Layout = null; // 👉 full màn hình cho đẹp
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Register</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            height: 100vh;
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            /* 🔥 background gradient */
            background: linear-gradient(135deg, #4e73df, #6f42c1);
            overflow: hidden;
        }

        /* 🔥 shape cong dưới */
        .bg-shape {
            position: absolute;
            bottom: 0;
            width: 100%;
            height: 40%;
            background: white;
            border-top-left-radius: 100% 60px;
            border-top-right-radius: 100% 60px;
        }

        .register-card {
            border-radius: 15px;
            z-index: 10;
        }

        .form-control:focus {
            box-shadow: none;
            border-color: #4e73df;
        }

        .btn-primary:hover {
            background-color: #2e59d9;
        }

        .register-card {
            animation: fadeIn 0.6s ease-in-out;
        }

        keyframes fadeIn {
            from

        {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }
    </style>
</head>
<body>

    <div class="d-flex justify-content-center align-items-center vh-100">

        <div class="card shadow-lg p-4 register-card" style="width: 400px;">

            <h3 class="text-center mb-3">Đăng ký</h3>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <form asp-action="Register" method="post">

                <div class="mb-3">
                    <input asp-for="FullName" class="form-control" placeholder="Họ tên" />
                </div>

                <div class="mb-3">
                    <input asp-for="Email" class="form-control" placeholder="Email" />
                </div>

                <div class="mb-3">
                    <input name="Password" type="password" class="form-control" placeholder="Mật khẩu" />
                </div>

                <div class="mb-3">
                    <input name="ConfirmPassword" type="password" class="form-control" placeholder="Xác nhận mật khẩu" />
                </div>

                <button class="btn btn-primary w-100">
                    Đăng ký
                </button>

            </form>

            <div class="text-center mt-3">
                <a asp-action="Login">Đã có tài khoản? Đăng nhập</a>
            </div>

        </div>

    </div>

    <!-- background shape -->
    <div class="bg-shape"></div>

</body>
</html>