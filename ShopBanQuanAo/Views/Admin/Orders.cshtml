@model List<Order>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h3><i class="bi bi-box2-heart-fill"></i> Quản lý đơn hàng</h3>

<table class="table table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>Mã</th>
            <th>Khách</th>
            <th>Ngày</th>
            <th>Tổng</th>
            <th>Trạng thái</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var o in Model)
        {
            <tr>
                <td>#@o.Id</td>
                <td>@o.User?.FullName</td>
                <td>@o.OrderDate.ToString("dd/MM/yyyy")</td>
                <td class="text-danger">@o.TotalAmount.ToString("N0") đ</td>

                <td>
                    <span class="badge bg-info">@o.Status</span>
                </td>

                <td class="d-flex gap-2">

                    <!-- Detail -->
                    <a asp-controller="Order"
                       asp-action="Detail"
                       asp-route-id="@o.Id"
                       class="btn btn-primary btn-sm">
                        <i class="bi bi-eye"></i> Detail
                    </a>

                    <!-- Status -->
                    <a asp-action="UpdateStatus"
                       asp-route-id="@o.Id"
                       asp-route-status="Confirmed"
                       class="btn btn-success btn-sm">
                        <i class="bi bi-check2-circle"></i> Confirm
                    </a>

                    <a asp-action="UpdateStatus"
                       asp-route-id="@o.Id"
                       asp-route-status="Shipping"
                       class="btn btn-warning btn-sm">
                        <i class="bi bi-truck"></i> Ship
                    </a>

                    <a asp-action="UpdateStatus"
                       asp-route-id="@o.Id"
                       asp-route-status="Completed"
                       class="btn btn-dark btn-sm">
                        <i class="bi bi-check-square-fill"></i> Done
                    </a>

                </td>
            </tr>
        }
    </tbody>
</table>