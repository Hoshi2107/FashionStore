@model List<CartItem>

<div class="container mt-4">

    <h3 class="mb-4"><i class="bi bi-basket"></i> Giỏ hàng</h3>
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary mb-3">
        ← Tiếp tục mua sắm
    </a>
    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Giỏ hàng trống
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="card mb-3 shadow-sm">
                <div class="row g-0 align-items-center">

                    <!-- IMAGE -->
                    <div class="col-md-2 text-center p-2">
                        <img src="~/images/@item.ImageUrl"
                             class="img-fluid rounded"
                             style="max-height:100px;" />
                    </div>

                    <!-- INFO -->
                    <div class="col-md-4">
                        <div class="card-body">
                            <h6>@item.Name</h6>
                            <p class="text-danger fw-bold">
                                @item.Price.ToString("N0") đ
                            </p>
                        </div>
                    </div>

                    <!-- QUANTITY -->
                    <div class="col-md-3 text-center">

                        <div class="d-flex justify-content-center align-items-center gap-2">

                            <a asp-action="Decrease"
                               asp-route-id="@item.ProductId"
                               class="btn btn-outline-secondary btn-sm">-</a>

                            <span class="fw-bold">@item.Quantity</span>

                            <a asp-action="Increase"
                               asp-route-id="@item.ProductId"
                               class="btn btn-outline-secondary btn-sm">+</a>

                        </div>

                    </div>

                    <!-- TOTAL -->
                    <div class="col-md-2 text-center">
                        <span class="text-danger fw-bold">
                            @(item.Price* item.Quantity) đ
                        </span>
                    </div>

                    <!-- REMOVE -->
                    <div class="col-md-1 text-center">
                        <a asp-action="Remove"
                           asp-route-id="@item.ProductId"
                           class="btn btn-danger btn-sm">
                            ✕
                        </a>
                    </div>

                </div>
            </div>
        }

        <!-- TOTAL -->
        <div class="text-end mt-4">
            <h4>
                Tổng tiền:
                <span class="text-danger">
                    @Model.Sum(x => x.Price * x.Quantity) đ
                </span>
            </h4>

            <a asp-action="Checkout" class="btn btn-success me-2">
                Thanh toán
            </a>

          @*   <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                Tiếp tục mua
            </a> *@
        </div>
    }

</div>