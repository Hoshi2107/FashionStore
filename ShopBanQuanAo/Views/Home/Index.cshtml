<div id="chatBox">

    <!-- HEADER -->
    <div id="chatHeader">
        <span><i class="bi bi-robot"></i> Fashion Bot</span>
        <span onclick="toggleChat()" style="cursor:pointer"><i class="bi bi-x-circle"></i></span>
    </div>

    <!-- MESSAGES -->
    <div id="messages"></div>

    <!-- INPUT -->
    <div id="chatInput">
        <input id="inputMsg" placeholder="Nhắn tin..." />
        <button onclick="sendMsg()">➤</button>
    </div>

</div>
<!-- BODY -->

<!-- BANNER -->
<img src="~/banner/Banner1.jpg" class="img-fluid w-100" style="max-height:500px; margin-top:20px; border-radius: 15px" />


<div class="container mt-4">
    @{
        var categories = ViewBag.Categories as List<Category>;
        int? selectedCategory = ViewBag.CategoryId;
    }

    <div class="category-wrapper mb-4 mt-1">
        <div class="category-scroll">

            <!-- Tất cả -->
            <a asp-action="Index"
               asp-route-categoryId=""
               asp-route-keyword="@ViewBag.Keyword"
               class="category-item @(selectedCategory == null ? "active" : "")">
                Tất cả
            </a>

            @foreach (var c in categories)
            {
                <a asp-action="Index"
                   asp-route-categoryId="@c.Id"
                   asp-route-keyword="@ViewBag.Keyword"
                   class="category-item @(selectedCategory == c.Id ? "active" : "")">
                    @c.Name
                </a>
            }

        </div>
    </div>

    <h3 class="mb-4" id="product-list"><i class="bi bi-fire"></i> Sản phẩm mới</h3>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card shadow-sm h-100">

                    <img src="~/images/@item.ImageUrl"
                         class="card-img-top"
                         style="height:250px; object-fit:cover;" />

                    <div class="card-body d-flex flex-column">

                        <h6 class="card-title">@item.Name</h6>

                        <p class="text-danger fw-bold">
                            @item.Price.ToString("N0") đ
                        </p>

                        <!-- đẩy nút xuống đáy -->
                        <div class="mt-auto">
                            @if (item.IsActive && item.Stock > 0)
                            {
                                <a asp-controller="Cart"
                                   asp-action="AddToCart"
                                   asp-route-id="@item.Id"
                                   class="btn btn-primary w-100 mb-3">
                                    <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-secondary w-100 mb-3" disabled>
                                    ❌ Hết hàng
                                </button>
                            }
                            <a asp-controller="Home"
                               asp-action="Detail"
                               asp-route-id="@item.Id"
                               class="btn btn-primary w-100">
                                Xem chi tiết
                            </a>
                        </div>

                    </div>
                </div> 
               

            </div>
        }
    </div>

  @*   @{
        int currentPage = ViewBag.CurrentPage ?? 1;
        int totalPages = ViewBag.TotalPages ?? 1;
        string keyword = ViewBag.Keyword as string;
    } *@

    @{
        int currentPage = ViewBag.CurrentPage;
        int totalPages = ViewBag.TotalPages;
        string keyword = ViewBag.Keyword as string;
        int start = Math.Max(1, currentPage - 2);
        int end = Math.Min(totalPages, currentPage + 2);
    }
    <p class="text-center">
        Trang @currentPage / @totalPages
    </p>
    <nav class="mt-4">
        <ul class="pagination justify-content-center">

            <!-- Prev -->
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(currentPage - 1)"
                   asp-route-keyword="@keyword"
                   asp-route-categoryId="@ViewBag.CategoryId">
                    Previous
                </a>
            </li>

            <!-- Page numbers -->
            @* @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-keyword="@keyword">
                        @i
                    </a>
                </li>
            } *@
            @for (int i = start; i <= end; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-keyword="@ViewBag.Keyword"
                       asp-route-categoryId="@ViewBag.CategoryId"
                    >
                        @i
                    </a>
                </li>
            }

            <!-- Next -->
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(currentPage + 1)"
                   asp-route-keyword="@keyword"
                   asp-route-categoryId="@ViewBag.CategoryId">
                    Next
                </a>
            </li>

        </ul>
    </nav>
</div>

@*Modal*@
<div class="modal fade" id="cartModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center p-4">

            <h4 class="text-success">✔ Đã thêm vào giỏ!</h4>
            <p id="modalProductName"></p>

            <div class="mt-3">
                <a href="/Cart" class="btn btn-primary me-2">
                    Xem giỏ hàng
                </a>
                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    Tiếp tục mua
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    const slider = document.querySelector('.category-scroll');

    let isDown = false;
    let startX;
    let scrollLeft;

    slider.addEventListener('mousedown', (e) => {
        isDown = true;
        slider.classList.add('dragging');
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
    });

    slider.addEventListener('mouseleave', () => {
        isDown = false;
        slider.classList.remove('dragging');
    });

    slider.addEventListener('mouseup', () => {
        isDown = false;
        slider.classList.remove('dragging');
    });

    slider.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - slider.offsetLeft;
        const walk = (x - startX) * 1.5; // tốc độ kéo
        slider.scrollLeft = scrollLeft - walk;
    });

    @* Chatbot *@

    const chatBtn = document.getElementById("chatBtn");
    const chatBox = document.getElementById("chatBox");

    chatBtn.onclick = () => {
        chatBox.style.display = chatBox.style.display === "none" ? "flex" : "none";
    };

        function sendMsg() {
        let msg = document.getElementById("inputMsg").value;

        document.getElementById("messages").innerHTML +=
            `<p class="user-msg">${msg}</p><div style="clear:both"></div>`;

        fetch('/Chat/Ask', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: msg })
        })
        .then(res => res.json())
        .then(data => {

            if (data.type === "text") {
                document.getElementById("messages").innerHTML +=
                    `<p class="bot-msg">${data.reply}</p>`;
            }

            if (data.type === "product") {
                document.getElementById("messages").innerHTML +=
                    `<p class="bot-msg">${data.reply}</p>`;

                data.data.forEach(p => {
                    document.getElementById("messages").innerHTML += `
                        <div style="background:white; border-radius:10px; padding:10px; margin-top:5px">
                            <img src="/images/${p.imageUrl}" style="width:100%; border-radius:10px"/>
                            <b>${p.name}</b>
                            <p style="color:red">${p.price.toLocaleString()} đ</p>
                            <a href="/Home/Detail/${p.id}" class="btn btn-sm btn-primary">Xem</a>
                        </div>
                    `;
                });
            }

            scrollBottom();
        });
    }

    @* toggle *@
        function toggleChat() {
        chatBox.style.display =
            chatBox.style.display === "none" ? "flex" : "none";
    }

    @* // auto scroll xuống cuối *@
    function scrollBottom() {
        let box = document.getElementById("messages");
        box.scrollTop = box.scrollHeight;
    }

        @* // Thêm vào cuối *@
    document.querySelector('form[action*="Index"]')?.addEventListener('submit', function() {
        sessionStorage.setItem('scrollToProducts', '1');
    });

    window.addEventListener('load', function() {
        if (sessionStorage.getItem('scrollToProducts') === '1') {
            sessionStorage.removeItem('scrollToProducts');
            const el = document.getElementById('product-list');
            if (el) el.scrollIntoView({ behavior: 'smooth' });
        }
    });

    @*     // Thêm vào cuối <script>
    // Scroll về product-list khi có filter/search params *@
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has('categoryId') || urlParams.has('keyword') || urlParams.has('page')) {
        const el = document.getElementById('product-list');
        if (el) el.scrollIntoView({ behavior: 'smooth' });
    }
</script>