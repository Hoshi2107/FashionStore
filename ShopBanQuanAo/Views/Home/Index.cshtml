@{
    ViewData["Title"] = "Home";
}
@model List<Product>


<style>
    .logo {
        font-weight: bold;
        font-size: 22px;
        color: #4e73df;
    }

    .cart-badge {
        position: absolute;
        top: -5px;
        right: -10px;
        font-size: 12px;
    }

    .category-wrapper {
        position: relative;
        overflow: hidden;
    }

    /* Scroll ngang */
    .category-scroll {
        display: flex;
        gap: 10px;
        overflow-x: auto;
        padding-bottom: 10px;
        scroll-behavior: smooth;
        padding-top: 50px;
        cursor: grab;
    }

        /* Ẩn scrollbar */
        .category-scroll::-webkit-scrollbar {
            display: none;
        }

    /* Item */
    .category-item {
        flex: 0 0 auto;
        padding: 8px 16px;
        background: #f1f1f1;
        border-radius: 20px;
        text-decoration: none;
        color: #333;
        transition: all 0.25s ease;
        white-space: nowrap;
    }

        /* Hover nảy lên */
        .category-item:hover {
            transform: translateY(-5px) scale(1.05);
            background: #4e73df;
            color: #fff;
        }

        /* Active */
        .category-item.active {
            background: #4e73df;
            color: white;
            font-weight: 500;
        }

    /* Shadow bên phải */
    .category-wrapper::after {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        width: 60px;
        height: 100%;
        pointer-events: none;
        background: linear-gradient(to left, white, transparent);
    }

    .category-scroll.dragging {
        cursor: grabbing;
    }

    /* tránh select text khi kéo */
    .category-scroll a {
        user-select: none;
    }

