    #chatBtn {
        position: fixed;
        bottom: 20px;
        right: 20px;
        background: #4e73df;
        color: white;
        border: none;
        border-radius: 50%;
        width: 60px;
        height: 60px;
        font-size: 24px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        cursor: pointer;
        z-index: 9999; /* 🔥 thêm cái này */
    }

    #chatBox {
        position: fixed;
        bottom: 90px;
        right: 20px;
        width: 320px;
        height: 420px;
        background: white;
        border-radius: 15px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.3);
        display: none;
        flex-direction: column;
        overflow: hidden;
        z-index: 9999; /* 🔥 cực kỳ quan trọng */
    }

    #chatHeader {
        background: #4e73df;
        color: white;
        padding: 10px;
        font-weight: bold;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    #messages {
        flex: 1;
        overflow-y: auto;
        padding: 10px;
        background: #f9f9f9;
    }

        /* Tin nhắn */
        #messages p {
            margin: 5px 0;
        }

    /* Bot */
    .bot-msg {
        background: #e4e6eb;
        padding: 8px 12px;
        border-radius: 10px;
        display: inline-block;
    }

    /* User */
    .user-msg {
        background: #4e73df;
        color: white;
        padding: 8px 12px;
        border-radius: 10px;
        display: inline-block;
        float: right;
    }

      /*   #messages {
            height: 250px;
            overflow-y: auto;
            padding: 10px;
        } */

    #chatInput {
        border-top: 1px solid #ddd;
        display: flex;
    }

        #chatInput input {
            flex: 1;
            border: none;
            padding: 10px;
        }

        #chatInput button {
            border: none;
            background: #4e73df;
            color: white;
            padding: 10px;
        }


